# ============================================================================
# WMS-AE Frontend — Required Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — only .env.example is tracked.
# ============================================================================

# ── Supabase (REQUIRED) ────────────────────────────────────────────────────
# Your Supabase project URL and anon (public) key.
# Find these in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Edge Functions URL (OPTIONAL) ──────────────────────────────────────────
# Override for local dev: http://127.0.0.1:54321/functions/v1
# Leave unset in production — auto-derives from VITE_SUPABASE_URL.
# VITE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

# ── PDF Microservice (REQUIRED for dispatch workflow) ──────────────────────
# Azure Container App URL and API key for PDF generation
VITE_PDF_SERVICE_URL=https://your-pdf-service.azurecontainerapps.io
VITE_PDF_SERVICE_API_KEY=your-pdf-api-key-here
