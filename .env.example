# ============================================================================
# Warehouse Management System — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to Git.
# ============================================================================

# ── Supabase Configuration ──
# Your Supabase project URL and public anon key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── PDF Service (Docker/NGINX only) ──
# API key injected into the NGINX container at startup via envsubst.
# Pass to Docker: docker run --env PDF_API_KEY=... 
PDF_API_KEY=your-pdf-service-api-key-here
