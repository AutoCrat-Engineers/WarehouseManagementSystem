# ============================================================================
# Dependencies
# ============================================================================
node_modules/
jspm_packages/
vendor/
.agents/

# ============================================================================
# Build Outputs
# ============================================================================
build/
dist/
out/
.next/
.turbo/
.nuxt/
.vercel/
*.tsbuildinfo

# ============================================================================
# Environment Variables (NEVER commit secrets — .env.example is allowed)
# ============================================================================
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local
!.env.example
!**/.env.example

# ============================================================================
# Local Database References
# ============================================================================
.db/
.db_reference/

# ============================================================================
# Supabase — keep functions & migrations tracked, ignore local state
# ============================================================================
supabase/.branches/
supabase/.temp/
supabase/functions/.env
supabase.exe
supabase.tar.gz

# ============================================================================
# Legacy Directories (moved to micro-services or .db_reference)
# ============================================================================
config/
server/

# ============================================================================
# Internal / AI Prompts (local reference only)
# ============================================================================
Prompt/

# ============================================================================
# Resolved Migration Plans (historical, kept locally)
# ============================================================================
docs/migration_plan.md.resolved

# ============================================================================
# Dev Scripts (ad-hoc local scripts — only README is tracked)
# ============================================================================
scripts/dev/*
!scripts/dev/README.md

# ============================================================================
# IDE / Editor Configs
# ============================================================================
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.project
.classpath

# ============================================================================
# OS Generated Files
# ============================================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
desktop.ini

# ============================================================================
# Logs & Debug Output
# ============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/
log.txt
log2.txt

# ============================================================================
# Debug / Diagnostic Artifacts
# ============================================================================
tsc_output.txt
git_log_output.txt
git_status_output.txt

# ============================================================================
# Vite / Build Caches
# ============================================================================
.vite/
.cache/

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
*.bak
tmp/
temp/

# ============================================================================
# Test Coverage & Caches
# ============================================================================
coverage/
.nyc_output/
.jest-cache/

# ============================================================================
# Scratch / Test Scripts (never commit ad-hoc test files at root)
# ============================================================================
test*.js
test*.mjs
*.conf.bak

# ============================================================================
# Misc
# ============================================================================
*.local
