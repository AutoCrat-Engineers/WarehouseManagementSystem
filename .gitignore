node_modules/
jspm_packages/
vendor/
.agents/

# ============================================================================
# Build Outputs
# ============================================================================
build/
dist/
out/
.next/
.turbo/
.nuxt/
.vercel/
*.tsbuildinfo

# ============================================================================
# Environment Variables (NEVER commit secrets — .env.example is allowed)
# ============================================================================
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local
!.env.example
!**/.env.example

# ============================================================================
# Local Database References & SQL Scripts
# ============================================================================
.db/
.db_reference/
sql/

# ============================================================================
# Supabase — keep functions & config tracked, ignore local state & migrations
# ============================================================================
supabase/.env.local
supabase/.branches/
supabase/.temp/
supabase/functions/.env
supabase/functions/proxy.ts
supabase/functions/local-dev-server.ts
supabase/migrations/
supabase.exe
supabase.tar.gz

# ============================================================================
# Legacy Directories (moved to micro-services or .db_reference)
# ============================================================================
config/
server/
src/supabase/

# ============================================================================
# Internal / AI Prompts (local reference only)
# ============================================================================
Prompt/

# ============================================================================
# Resolved Migration Plans (historical, kept locally)
# ============================================================================
docs/migration_plan.md.resolved

# ============================================================================
# Local Dev Scripts (Windows-only, not needed on remote)
# ============================================================================
deploy.ps1
start-auth-local.ps1
start-dev.ps1
verify-auth-local.ps1
scripts/dev/*
!scripts/dev/README.md

# ============================================================================
# Lock Files (regenerated per environment)
# ============================================================================
deno.lock

# ============================================================================
# Runtime Logs (local dev server output)
# ============================================================================
run-logs/

