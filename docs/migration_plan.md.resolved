## PHASE 7 — Security Hardening

### Script 7: `007_security_hardening.sql`

```sql
-- ============================================================================
-- MIGRATION 007: SECURITY HARDENING
-- RLS policies, privilege escalation prevention, immutable audit
-- ============================================================================

BEGIN;

-- ──────────────────────────────────────────────────────────────────────────────
-- 1. RLS ON user_permissions
-- ──────────────────────────────────────────────────────────────────────────────
ALTER TABLE public.user_permissions ENABLE ROW LEVEL SECURITY;

-- Users can read their OWN permissions
DROP POLICY IF EXISTS "Users read own permissions" ON public.user_permissions;
CREATE POLICY "Users read own permissions" ON public.user_permissions
  FOR SELECT TO authenticated
  USING (user_id = auth.uid());

-- L3 can read ALL user permissions
DROP POLICY IF EXISTS "L3 read all permissions" ON public.user_permissions;
CREATE POLICY "L3 read all permissions" ON public.user_permissions
  FOR SELECT TO authenticated
  USING (
    EXISTS (SELECT 1 FROM public.profiles WHERE id = auth.uid() AND role = 'L3' AND is_active = true)
  );

-- L3 can INSERT/UPDATE/DELETE user permissions
DROP POLICY IF EXISTS "L3 manage permissions" ON public.user_permissions;
CREATE POLICY "L3 manage permissions" ON public.user_permissions
  FOR ALL TO authenticated
  USING (
    EXISTS (SELECT 1 FROM public.profiles WHERE id = auth.uid() AND role = 'L3' AND is_active = true)
  )
  WITH CHECK (
    EXISTS (SELECT 1 FROM public.profiles WHERE id = auth.uid() AND role = 'L3' AND is_active = true)
  );

-- ──────────────────────────────────────────────────────────────────────────────
-- 2. PRIVILEGE ESCALATION PREVENTION
-- Prevent non-L3 users from granting themselves higher permissions
-- ──────────────────────────────────────────────────────────────────────────────
CREATE OR REPLACE FUNCTION public.prevent_self_escalation()
RETURNS TRIGGER AS $$
DECLARE
  _caller_role varchar;
BEGIN
  -- Get caller's role
  SELECT role INTO _caller_role
  FROM public.profiles
  WHERE id = auth.uid() AND is_active = true;

  -- Only L3 can modify permissions
  IF _caller_role IS DISTINCT FROM 'L3' THEN
    RAISE EXCEPTION 'PRIVILEGE ESCALATION BLOCKED: Only L3 managers can modify user permissions. Your role: %', COALESCE(_caller_role, 'UNKNOWN');
  END IF;

  -- L3 cannot grant permissions to themselves (already full access)
  IF NEW.user_id = auth.uid() THEN
    RAISE EXCEPTION 'SELF-GRANT BLOCKED: L3 users cannot modify their own permission overrides.';
  END IF;

  -- Stamp the override metadata
  NEW.overridden_by := auth.uid();
  NEW.overridden_at := now();

  RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER SET search_path = public;

DROP TRIGGER IF EXISTS trigger_prevent_escalation ON public.user_permissions;
CREATE TRIGGER trigger_prevent_escalation
  BEFORE INSERT OR UPDATE ON public.user_permissions
  FOR EACH ROW
  EXECUTE FUNCTION public.prevent_self_escalation();

-- ──────────────────────────────────────────────────────────────────────────────
-- 3. RLS ON module_registry (read-only for all, writable by L3)
-- ──────────────────────────────────────────────────────────────────────────────
ALTER TABLE public.module_registry ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS "All can read modules" ON public.module_registry;
CREATE POLICY "All can read modules" ON public.module_registry
  FOR SELECT TO authenticated USING (true);

DROP POLICY IF EXISTS "L3 can manage modules" ON public.module_registry;
CREATE POLICY "L3 can manage modules" ON public.module_registry
  FOR ALL TO authenticated
  USING (
    EXISTS (SELECT 1 FROM public.profiles WHERE id = auth.uid() AND role = 'L3')
  )
  WITH CHECK (
    EXISTS (SELECT 1 FROM public.profiles WHERE id = auth.uid() AND role = 'L3')
  );

RAISE NOTICE '✅ Security hardening complete';

COMMIT;
```

---

## PHASE 8 — Rollback Scripts (CRITICAL)

### Rollback Level 1: Instant Feature Flag Revert

```sql
-- ROLLBACK LEVEL 1: Switch permission source back to localStorage
-- Effect: Instant, zero-downtime, no data loss
-- When: If DB permissions are returning wrong results
SELECT public.advance_permission_rollout('localStorage');
-- Frontend will immediately start reading from localStorage again
```

### Rollback Level 2: Restore Role-Only Behavior

```sql
-- ROLLBACK LEVEL 2: Disable all user overrides without deleting them
-- Effect: System falls back to pure role-based permissions (L1/L2/L3 defaults)
-- When: If user_permissions data is corrupted or incorrect

BEGIN;

-- Option A: Soft-disable by truncating (preserves table structure)
-- Save a backup first
CREATE TABLE IF NOT EXISTS public.user_permissions_backup AS
  SELECT * FROM public.user_permissions;

-- Clear all overrides — system will use role defaults only
TRUNCATE public.user_permissions;

-- Revert feature flag
SELECT public.advance_permission_rollout('localStorage');

RAISE NOTICE '✅ Level 2 rollback complete: role-only permissions restored';
RAISE NOTICE '   Backup saved in user_permissions_backup table';

COMMIT;
```

### Rollback Level 3: Full Schema Removal (Nuclear Option)

```sql
-- ROLLBACK LEVEL 3: Drop all new migration objects
-- Effect: System returns to EXACT pre-migration state
-- When: ONLY if entire migration must be abandoned
--
-- ⚠️  THIS IS DESTRUCTIVE — but safe because:
--    1. We backup user_permissions first
--    2. We restore original module names in permissions table
--    3. Old localStorage code still works

BEGIN;

-- 1. Backup user_permissions before dropping
CREATE TABLE IF NOT EXISTS public.user_permissions_archive AS
  SELECT *, now() AS archived_at FROM public.user_permissions;

-- 2. Drop triggers first (dependency order)
DROP TRIGGER IF EXISTS trigger_prevent_escalation ON public.user_permissions;
DROP TRIGGER IF EXISTS trigger_audit_perm_change ON public.user_permissions;
DROP TRIGGER IF EXISTS trigger_user_permissions_updated_at ON public.user_permissions;

-- 3. Drop functions
DROP FUNCTION IF EXISTS public.get_effective_permissions(uuid);
DROP FUNCTION IF EXISTS public.check_user_permission(uuid, varchar, varchar);
DROP FUNCTION IF EXISTS public.prevent_self_escalation();
DROP FUNCTION IF EXISTS public.audit_permission_change();
DROP FUNCTION IF EXISTS public.advance_permission_rollout(varchar);
DROP FUNCTION IF EXISTS public.get_permission_source();

-- 4. Drop tables (order matters due to FKs)
DROP TABLE IF EXISTS public.perm_migration_staging;
DROP TABLE IF EXISTS public.user_permissions;
DROP TABLE IF EXISTS public.system_settings;
DROP TABLE IF EXISTS public.module_registry;

-- 5. Restore original module names in permissions (if backup column exists)
DO $$
BEGIN
  IF EXISTS (
    SELECT 1 FROM information_schema.columns
    WHERE table_schema = 'public' AND table_name = 'permissions'
      AND column_name = 'original_module'
  ) THEN
    UPDATE public.permissions SET module = original_module WHERE original_module IS NOT NULL;
    ALTER TABLE public.permissions DROP COLUMN original_module;
    RAISE NOTICE '✅ Restored original module names in permissions table';
  END IF;
END $$;

-- 6. Remove packing/notification rows that were added to permissions
DELETE FROM public.permissions WHERE module LIKE 'packing.%';
DELETE FROM public.permissions WHERE module = 'notifications';

RAISE NOTICE '╔══════════════════════════════════════════════╗';
RAISE NOTICE '║  LEVEL 3 ROLLBACK COMPLETE                   ║';
RAISE NOTICE '║  All new objects dropped.                     ║';
RAISE NOTICE '║  permissions table restored to original.      ║';
RAISE NOTICE '║  Archive saved in user_permissions_archive.   ║';
RAISE NOTICE '╚══════════════════════════════════════════════╝';

COMMIT;
```

