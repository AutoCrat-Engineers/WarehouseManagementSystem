## PHASE 9 — Validation Queries

### Script 8: `008_validation_queries.sql`

```sql
-- ============================================================================
-- POST-MIGRATION VALIDATION QUERIES
-- Run these to verify migration integrity
-- ============================================================================

-- ─── 1. Permission parity check ─────────────────────────────────────────────
-- Compare user_permissions row count vs expected (from staging)
SELECT
  'staging_rows' AS metric,
  count(*) AS count
FROM public.perm_migration_staging
WHERE migration_status = 'MERGED'
UNION ALL
SELECT
  'user_permission_rows',
  count(*)
FROM public.user_permissions
UNION ALL
SELECT
  'failed_staging_rows',
  count(*)
FROM public.perm_migration_staging
WHERE migration_status = 'FAILED';

-- ─── 2. Users missing permission overrides ───────────────────────────────────
-- Users who were in localStorage but have no DB overrides
SELECT p.id, p.email, p.role, p.full_name
FROM public.profiles p
LEFT JOIN public.user_permissions up ON up.user_id = p.id
WHERE up.id IS NULL
  AND p.role IN ('L1', 'L2')
  AND p.is_active = true
  AND p.deleted_at IS NULL
ORDER BY p.role, p.email;

-- ─── 3. Orphan overrides (permissions for deleted/inactive users) ────────────
SELECT up.*, p.email, p.is_active, p.deleted_at
FROM public.user_permissions up
JOIN public.profiles p ON p.id = up.user_id
WHERE p.is_active = false OR p.deleted_at IS NOT NULL;

-- ─── 4. Module coverage check ────────────────────────────────────────────────
-- Modules in registry vs modules that have role defaults
SELECT mr.module_key,
       EXISTS (SELECT 1 FROM public.permissions WHERE module = mr.module_key) AS has_role_defaults,
       (SELECT count(*) FROM public.user_permissions WHERE module_name = mr.module_key) AS override_count
FROM public.module_registry mr
ORDER BY mr.sort_order;

-- ─── 5. Effective permissions sample ─────────────────────────────────────────
-- Verify get_effective_permissions() works for each role level
-- Replace UUIDs with actual user IDs from your system
DO $$
DECLARE
  _l1_user uuid;
  _l2_user uuid;
  _l3_user uuid;
  _row RECORD;
BEGIN
  SELECT id INTO _l1_user FROM profiles WHERE role = 'L1' AND is_active = true LIMIT 1;
  SELECT id INTO _l2_user FROM profiles WHERE role = 'L2' AND is_active = true LIMIT 1;
  SELECT id INTO _l3_user FROM profiles WHERE role = 'L3' AND is_active = true LIMIT 1;

  IF _l1_user IS NOT NULL THEN
    RAISE NOTICE '── L1 user permissions ──';
    FOR _row IN SELECT * FROM get_effective_permissions(_l1_user)
    LOOP
      RAISE NOTICE '  % | V:% C:% E:% D:% | %', _row.module_name, _row.can_view, _row.can_create, _row.can_edit, _row.can_delete, _row.source;
    END LOOP;
  END IF;

  IF _l2_user IS NOT NULL THEN
    RAISE NOTICE '── L2 user permissions ──';
    FOR _row IN SELECT * FROM get_effective_permissions(_l2_user)
    LOOP
      RAISE NOTICE '  % | V:% C:% E:% D:% | %', _row.module_name, _row.can_view, _row.can_create, _row.can_edit, _row.can_delete, _row.source;
    END LOOP;
  END IF;

  IF _l3_user IS NOT NULL THEN
    RAISE NOTICE '── L3 user permissions (should be all true) ──';
    FOR _row IN SELECT * FROM get_effective_permissions(_l3_user)
    LOOP
      RAISE NOTICE '  % | V:% C:% E:% D:% | %', _row.module_name, _row.can_view, _row.can_create, _row.can_edit, _row.can_delete, _row.source;
    END LOOP;
  END IF;
END $$;

-- ─── 6. Performance check ───────────────────────────────────────────────────
-- Time the function (should be < 10ms)
EXPLAIN ANALYZE
SELECT * FROM public.get_effective_permissions(
  (SELECT id FROM profiles WHERE role = 'L1' AND is_active = true LIMIT 1)
);

-- ─── 7. Feature flag status ─────────────────────────────────────────────────
SELECT * FROM public.system_settings WHERE key = 'permission_source';
```

