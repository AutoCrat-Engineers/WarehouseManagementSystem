## PHASE 5 — Permission Resolution Engine

### Script 5: `005_effective_permissions_function.sql`

```sql
-- ============================================================================
-- MIGRATION 005: PERMISSION RESOLUTION ENGINE
--
-- get_effective_permissions(p_user_id uuid)
--
-- Priority:
--   1. user_permissions (per-user override) — HIGHEST
--   2. permissions (role default)           — BASELINE
--   3. DENY                                 — DEFAULT
--
-- Returns one row per module with resolved can_view/create/edit/delete
-- ============================================================================

BEGIN;

CREATE OR REPLACE FUNCTION public.get_effective_permissions(p_user_id uuid)
RETURNS TABLE (
  module_name   varchar,
  can_view      boolean,
  can_create    boolean,
  can_edit      boolean,
  can_delete    boolean,
  source        varchar   -- 'override' or 'role_default'
)
LANGUAGE plpgsql
SECURITY DEFINER
SET search_path = public
AS $$
DECLARE
  _user_role varchar;
BEGIN
  -- Get user's role
  SELECT role INTO _user_role
  FROM public.profiles
  WHERE id = p_user_id AND is_active = true AND deleted_at IS NULL;

  IF _user_role IS NULL THEN
    -- User not found or inactive: return empty set (deny all)
    RETURN;
  END IF;

  -- L3 users: ALWAYS get full access (bypass overrides entirely)
  IF _user_role = 'L3' THEN
    RETURN QUERY
    SELECT
      mr.module_key::varchar,
      true::boolean,
      true::boolean,
      true::boolean,
      true::boolean,
      'l3_full_access'::varchar
    FROM public.module_registry mr
    WHERE mr.is_active = true;
    RETURN;
  END IF;

  -- For L1/L2: merge role defaults with user overrides
  RETURN QUERY
  SELECT
    mr.module_key::varchar AS module_name,
    -- Override takes priority, else role default, else false
    COALESCE(
      up.can_view,
      (SELECT p.is_allowed FROM public.permissions p
       WHERE p.role_id = _user_role AND p.module = mr.module_key AND p.action = 'view'),
      false
    )::boolean AS can_view,
    COALESCE(
      up.can_create,
      (SELECT p.is_allowed FROM public.permissions p
       WHERE p.role_id = _user_role AND p.module = mr.module_key AND p.action = 'create'),
      false
    )::boolean AS can_create,
    COALESCE(
      up.can_edit,
      (SELECT p.is_allowed FROM public.permissions p
       WHERE p.role_id = _user_role AND p.module = mr.module_key AND p.action = 'edit'),
      false
    )::boolean AS can_edit,
    COALESCE(
      up.can_delete,
      (SELECT p.is_allowed FROM public.permissions p
       WHERE p.role_id = _user_role AND p.module = mr.module_key AND p.action = 'delete'),
      false
    )::boolean AS can_delete,
    CASE
      WHEN up.id IS NOT NULL THEN 'override'
      ELSE 'role_default'
    END::varchar AS source
  FROM public.module_registry mr
  LEFT JOIN public.user_permissions up
    ON up.user_id = p_user_id AND up.module_name = mr.module_key
  WHERE mr.is_active = true;
END;
$$;

-- Convenience: check a single permission
CREATE OR REPLACE FUNCTION public.check_user_permission(
  p_user_id uuid,
  p_module varchar,
  p_action varchar  -- 'view', 'create', 'edit', 'delete'
)
RETURNS boolean
LANGUAGE plpgsql
SECURITY DEFINER
SET search_path = public
AS $$
DECLARE
  _result boolean;
  _user_role varchar;
BEGIN
  SELECT role INTO _user_role
  FROM public.profiles
  WHERE id = p_user_id AND is_active = true AND deleted_at IS NULL;

  IF _user_role IS NULL THEN RETURN false; END IF;
  IF _user_role = 'L3' THEN RETURN true; END IF;

  -- Check user override first
  EXECUTE format(
    'SELECT %I FROM public.user_permissions WHERE user_id = $1 AND module_name = $2',
    'can_' || p_action
  ) INTO _result USING p_user_id, p_module;

  IF _result IS NOT NULL THEN RETURN _result; END IF;

  -- Fall back to role default
  SELECT is_allowed INTO _result
  FROM public.permissions
  WHERE role_id = _user_role AND module = p_module AND action = p_action;

  RETURN COALESCE(_result, false);
END;
$$;

RAISE NOTICE '✅ Permission resolution functions created';

COMMIT;
```

