## PHASE 3 — Module Name Normalization

### Script 2: `002_normalize_permissions_table.sql`

```sql
-- ============================================================================
-- MIGRATION 002: NORMALIZE existing permissions table module names
-- Maps old DB names → canonical frontend-compatible names
-- Safety: Updates IN PLACE but preserves original values in notes column first
-- ============================================================================

BEGIN;

-- ──────────────────────────────────────────────────────────────────────────────
-- 1. ADD backup column to permissions (if not exists)
-- ──────────────────────────────────────────────────────────────────────────────
DO $$
BEGIN
  IF NOT EXISTS (
    SELECT 1 FROM information_schema.columns
    WHERE table_schema = 'public' AND table_name = 'permissions'
      AND column_name = 'original_module'
  ) THEN
    ALTER TABLE public.permissions ADD COLUMN original_module varchar;
    RAISE NOTICE '✅ Added original_module backup column to permissions';
  ELSE
    RAISE NOTICE 'ℹ️  original_module column already exists — skipping';
  END IF;
END $$;

-- ──────────────────────────────────────────────────────────────────────────────
-- 2. BACKUP original values (only once — don't overwrite on re-run)
-- ──────────────────────────────────────────────────────────────────────────────
UPDATE public.permissions
SET original_module = module
WHERE original_module IS NULL;

-- ──────────────────────────────────────────────────────────────────────────────
-- 3. NORMALIZE module names (idempotent — uses canonical keys)
-- ──────────────────────────────────────────────────────────────────────────────
-- Map: DB old name → canonical frontend name

UPDATE public.permissions SET module = 'stock-movements'     WHERE module = 'stock_movements';
UPDATE public.permissions SET module = 'orders'              WHERE module = 'blanket_orders';
UPDATE public.permissions SET module = 'releases'            WHERE module = 'blanket_releases';
UPDATE public.permissions SET module = 'forecast'            WHERE module = 'forecasting';

-- NOTE: 'reports', 'settings' have no frontend equivalent yet — leave as-is.
-- They will still work via the DB but won't be visible in the UI.

-- ──────────────────────────────────────────────────────────────────────────────
-- 4. ADD MISSING MODULES to permissions table (packing submodules, notifications)
-- These were only in the frontend GrantAccessModal, never in DB.
-- ──────────────────────────────────────────────────────────────────────────────

-- L3 gets full access to new modules
INSERT INTO public.permissions (role_id, module, action, is_allowed) VALUES
  -- Packing submodules
  ('L3', 'packing.sticker-generation',       'view',   true),
  ('L3', 'packing.sticker-generation',       'create', true),
  ('L3', 'packing.sticker-generation',       'edit',   true),
  ('L3', 'packing.packing-details',          'view',   true),
  ('L3', 'packing.packing-details',          'create', true),
  ('L3', 'packing.packing-details',          'edit',   true),
  ('L3', 'packing.packing-details',          'delete', true),
  ('L3', 'packing.packing-list-invoice',     'view',   true),
  ('L3', 'packing.packing-list-invoice',     'create', true),
  ('L3', 'packing.packing-list-invoice',     'edit',   true),
  ('L3', 'packing.packing-list-invoice',     'delete', true),
  ('L3', 'packing.packing-list-sub-invoice', 'view',   true),
  ('L3', 'packing.packing-list-sub-invoice', 'create', true),
  ('L3', 'packing.packing-list-sub-invoice', 'edit',   true),
  ('L3', 'packing.packing-list-sub-invoice', 'delete', true),
  ('L3', 'notifications',                    'view',   true),
  -- L2 gets view + create on packing, view on notifications
  ('L2', 'packing.sticker-generation',       'view',   true),
  ('L2', 'packing.sticker-generation',       'create', true),
  ('L2', 'packing.sticker-generation',       'edit',   true),
  ('L2', 'packing.packing-details',          'view',   true),
  ('L2', 'packing.packing-details',          'create', true),
  ('L2', 'packing.packing-details',          'edit',   true),
  ('L2', 'packing.packing-details',          'delete', false),
  ('L2', 'packing.packing-list-invoice',     'view',   true),
  ('L2', 'packing.packing-list-invoice',     'create', true),
  ('L2', 'packing.packing-list-invoice',     'edit',   true),
  ('L2', 'packing.packing-list-invoice',     'delete', false),
  ('L2', 'packing.packing-list-sub-invoice', 'view',   true),
  ('L2', 'packing.packing-list-sub-invoice', 'create', true),
  ('L2', 'packing.packing-list-sub-invoice', 'edit',   true),
  ('L2', 'packing.packing-list-sub-invoice', 'delete', false),
  ('L2', 'notifications',                    'view',   true),
  -- L1 gets view only on packing, view on notifications
  ('L1', 'packing.sticker-generation',       'view',   true),
  ('L1', 'packing.sticker-generation',       'create', true),
  ('L1', 'packing.sticker-generation',       'edit',   false),
  ('L1', 'packing.packing-details',          'view',   true),
  ('L1', 'packing.packing-details',          'create', false),
  ('L1', 'packing.packing-details',          'edit',   false),
  ('L1', 'packing.packing-details',          'delete', false),
  ('L1', 'packing.packing-list-invoice',     'view',   true),
  ('L1', 'packing.packing-list-invoice',     'create', false),
  ('L1', 'packing.packing-list-invoice',     'edit',   false),
  ('L1', 'packing.packing-list-invoice',     'delete', false),
  ('L1', 'packing.packing-list-sub-invoice', 'view',   true),
  ('L1', 'packing.packing-list-sub-invoice', 'create', false),
  ('L1', 'packing.packing-list-sub-invoice', 'edit',   false),
  ('L1', 'packing.packing-list-sub-invoice', 'delete', false),
  ('L1', 'notifications',                    'view',   true)
ON CONFLICT (role_id, module, action) DO NOTHING;

-- ──────────────────────────────────────────────────────────────────────────────
-- 5. VERIFICATION
-- ──────────────────────────────────────────────────────────────────────────────
DO $$
DECLARE
  _old_names int;
BEGIN
  SELECT count(*) INTO _old_names
  FROM public.permissions
  WHERE module IN ('stock_movements', 'blanket_orders', 'blanket_releases', 'forecasting');

  IF _old_names = 0 THEN
    RAISE NOTICE '✅ All module names normalized — no legacy names remain';
  ELSE
    RAISE WARNING '⚠️  % rows still have legacy module names!', _old_names;
  END IF;
END $$;

COMMIT;
```

