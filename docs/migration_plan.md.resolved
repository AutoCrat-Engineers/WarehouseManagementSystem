## PHASE 6 — Feature Flag Strategy

> [!NOTE]
> The feature flag is implemented via a DB setting + frontend environment variable.
> This allows instant rollback without code deployment.

### Script 6: `006_feature_flag.sql`

```sql
-- ============================================================================
-- MIGRATION 006: FEATURE FLAG
-- Controls permission read source during migration rollout
-- ============================================================================

BEGIN;

CREATE TABLE IF NOT EXISTS public.system_settings (
  key         varchar NOT NULL,
  value       jsonb NOT NULL,
  updated_at  timestamptz DEFAULT now(),
  updated_by  uuid,
  CONSTRAINT system_settings_pkey PRIMARY KEY (key)
);

-- Feature flag values:
--   'localStorage'       → Phase 1: Read from localStorage (current behavior)
--   'db_with_fallback'   → Phase 2: Read from DB, fall back to localStorage
--   'db_only'            → Phase 3: DB is sole source of truth
--   'cleanup_done'       → Phase 4: localStorage code removed

INSERT INTO public.system_settings (key, value) VALUES
  ('permission_source', '"localStorage"'::jsonb)
ON CONFLICT (key) DO NOTHING;

-- RLS: All authenticated can read, only L3 can write
ALTER TABLE public.system_settings ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS "All can read settings" ON public.system_settings;
CREATE POLICY "All can read settings" ON public.system_settings
  FOR SELECT TO authenticated USING (true);

DROP POLICY IF EXISTS "L3 can manage settings" ON public.system_settings;
CREATE POLICY "L3 can manage settings" ON public.system_settings
  FOR ALL TO authenticated
  USING (
    EXISTS (SELECT 1 FROM public.profiles WHERE id = auth.uid() AND role = 'L3')
  )
  WITH CHECK (
    EXISTS (SELECT 1 FROM public.profiles WHERE id = auth.uid() AND role = 'L3')
  );

-- Convenience function to get current flag value
CREATE OR REPLACE FUNCTION public.get_permission_source()
RETURNS varchar
LANGUAGE sql
SECURITY DEFINER
SET search_path = public
STABLE
AS $$
  SELECT (value #>> '{}')::varchar
  FROM public.system_settings
  WHERE key = 'permission_source';
$$;

-- Rollout advancement function (L3 only)
CREATE OR REPLACE FUNCTION public.advance_permission_rollout(new_phase varchar)
RETURNS void
LANGUAGE plpgsql
SECURITY DEFINER
SET search_path = public
AS $$
BEGIN
  IF new_phase NOT IN ('localStorage', 'db_with_fallback', 'db_only', 'cleanup_done') THEN
    RAISE EXCEPTION 'Invalid phase: %. Must be one of: localStorage, db_with_fallback, db_only, cleanup_done', new_phase;
  END IF;

  UPDATE public.system_settings
  SET value = to_jsonb(new_phase),
      updated_at = now(),
      updated_by = auth.uid()
  WHERE key = 'permission_source';

  -- Audit log
  INSERT INTO public.audit_log (user_id, action, target_type, new_value)
  VALUES (auth.uid(), 'ADVANCE_PERMISSION_ROLLOUT', 'system', jsonb_build_object('phase', new_phase));

  RAISE NOTICE '✅ Permission source advanced to: %', new_phase;
END;
$$;

COMMIT;
```

### Frontend Rollout Strategy

```
┌──────────────────────────────────────────────────────────────┐
│                    DEPLOYMENT PHASES                         │
├──────────────────────────────────────────────────────────────┤
│                                                              │
│  Phase 1: 'localStorage'        ← CURRENT DEFAULT           │
│  ─────────────────────────                                   │
│  • Read from localStorage                                    │
│  • DB tables exist but unused by frontend                    │
│  • Safe: zero behavior change                                │
│                                                              │
│  Phase 2: 'db_with_fallback'    ← AFTER DATA INGESTION      │
│  ────────────────────────────                                │
│  • Read from DB via get_effective_permissions()              │
│  • If DB returns empty AND localStorage has data → use LS    │
│  • Compare results and log mismatches                        │
│  • Duration: 1-3 days monitoring                             │
│                                                              │
│  Phase 3: 'db_only'             ← AFTER VALIDATION          │
│  ─────────────────────                                       │
│  • Read ONLY from DB                                         │
│  • localStorage ignored completely                           │
│  • GrantAccessModal saves to DB instead of localStorage      │
│  • Duration: 1 week monitoring                               │
│                                                              │
│  Phase 4: 'cleanup_done'        ← FINAL                     │
│  ──────────────────────                                      │
│  • localStorage code removed from codebase                   │
│  • permissionService.ts rewritten to use DB                  │
│  • Staging table dropped                                     │
│                                                              │
│  🔴 ROLLBACK AT ANY PHASE:                                   │
│  SELECT advance_permission_rollout('localStorage');          │
│  → Instantly reverts to localStorage behavior                │
│                                                              │
└──────────────────────────────────────────────────────────────┘
```

