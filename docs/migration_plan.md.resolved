## PHASE 4 — Data Backfill Strategy (localStorage → Staging → DB)

### Script 3: `003_create_staging_table.sql`

```sql
-- ============================================================================
-- MIGRATION 003: STAGING TABLE for localStorage → DB ingestion
-- The frontend will push localStorage JSON here via Supabase insert.
-- Then a merge script moves validated data → user_permissions.
-- ============================================================================

BEGIN;

CREATE TABLE IF NOT EXISTS public.perm_migration_staging (
  id                uuid NOT NULL DEFAULT uuid_generate_v4(),
  user_id           uuid NOT NULL,
  raw_permissions   jsonb NOT NULL,           -- exact copy of localStorage JSON
  migration_status  varchar NOT NULL DEFAULT 'PENDING',
                    -- PENDING → VALIDATED → MERGED → FAILED
  validation_errors jsonb,                    -- any issues found
  merged_at         timestamptz,
  ingested_at       timestamptz NOT NULL DEFAULT now(),
  ingested_by       uuid,                     -- the L3 admin who triggered it

  CONSTRAINT perm_migration_staging_pkey PRIMARY KEY (id),
  CONSTRAINT perm_migration_staging_user_fkey FOREIGN KEY (user_id)
    REFERENCES public.profiles(id) ON DELETE CASCADE
);

-- RLS: Only L3 can insert/read staging data
ALTER TABLE public.perm_migration_staging ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS "L3 manage staging" ON public.perm_migration_staging;
CREATE POLICY "L3 manage staging" ON public.perm_migration_staging
  FOR ALL TO authenticated
  USING (
    EXISTS (
      SELECT 1 FROM public.profiles
      WHERE id = auth.uid() AND role = 'L3' AND is_active = true
    )
  )
  WITH CHECK (
    EXISTS (
      SELECT 1 FROM public.profiles
      WHERE id = auth.uid() AND role = 'L3' AND is_active = true
    )
  );

RAISE NOTICE '✅ Staging table created';

COMMIT;
```

### Script 4: `004_merge_staging_to_user_permissions.sql`

```sql
-- ============================================================================
-- MIGRATION 004: MERGE validated staging data → user_permissions
-- Run AFTER frontend has pushed localStorage data to staging table.
--
-- This script:
--   1. Validates staging rows
--   2. Transforms localStorage key format → relational rows
--   3. Upserts into user_permissions
--   4. Marks staging rows as MERGED
-- ============================================================================

BEGIN;

-- ──────────────────────────────────────────────────────────────────────────────
-- MODULE NAME MAP: localStorage key prefixes → canonical module_name
-- ──────────────────────────────────────────────────────────────────────────────
-- localStorage format: "module.action" or "module.submodule.action"
-- We need to derive:
--   module_name = "module" or "module.submodule"
--   action = "view" | "create" | "edit" | "delete"

-- Step 1: Validate staging entries
UPDATE public.perm_migration_staging
SET migration_status = 'VALIDATED',
    validation_errors = NULL
WHERE migration_status = 'PENDING'
  AND user_id IN (SELECT id FROM public.profiles WHERE deleted_at IS NULL);

-- Mark orphans
UPDATE public.perm_migration_staging
SET migration_status = 'FAILED',
    validation_errors = '{"error": "user_id not found in profiles"}'::jsonb
WHERE migration_status = 'PENDING'
  AND user_id NOT IN (SELECT id FROM public.profiles WHERE deleted_at IS NULL);

-- Step 2: Transform and merge
-- For each VALIDATED staging row, extract permissions and upsert
DO $$
DECLARE
  _row RECORD;
  _key TEXT;
  _value BOOLEAN;
  _parts TEXT[];
  _module TEXT;
  _action TEXT;
  _user_role TEXT;
  _merged_count INT := 0;
  _skipped_count INT := 0;
BEGIN
  FOR _row IN
    SELECT s.id, s.user_id, s.raw_permissions, p.role
    FROM public.perm_migration_staging s
    JOIN public.profiles p ON p.id = s.user_id
    WHERE s.migration_status = 'VALIDATED'
  LOOP
    _user_role := _row.role;

    -- Iterate over each key in the JSON
    FOR _key, _value IN
      SELECT key, (value)::boolean
      FROM jsonb_each_text(_row.raw_permissions)
    LOOP
      -- Parse the key: split by '.'
      _parts := string_to_array(_key, '.');

      IF array_length(_parts, 1) = 2 THEN
        -- Format: module.action (e.g. "items.view")
        _module := _parts[1];
        _action := _parts[2];
      ELSIF array_length(_parts, 1) = 3 THEN
        -- Format: module.submodule.action (e.g. "packing.sticker-generation.view")
        _module := _parts[1] || '.' || _parts[2];
        _action := _parts[3];
      ELSE
        _skipped_count := _skipped_count + 1;
        CONTINUE;  -- skip malformed keys
      END IF;

      -- Validate module exists in registry
      IF NOT EXISTS (SELECT 1 FROM public.module_registry WHERE module_key = _module) THEN
        _skipped_count := _skipped_count + 1;
        CONTINUE;
      END IF;

      -- Validate action is known
      IF _action NOT IN ('view', 'create', 'edit', 'delete') THEN
        _skipped_count := _skipped_count + 1;
        CONTINUE;
      END IF;

      -- Upsert the permission
      INSERT INTO public.user_permissions (
        user_id, module_name, source_role,
        can_view, can_create, can_edit, can_delete,
        overridden_by, overridden_at
      )
      VALUES (
        _row.user_id,
        _module,
        _user_role,
        CASE WHEN _action = 'view'   THEN _value ELSE false END,
        CASE WHEN _action = 'create' THEN _value ELSE false END,
        CASE WHEN _action = 'edit'   THEN _value ELSE false END,
        CASE WHEN _action = 'delete' THEN _value ELSE false END,
        auth.uid(),
        now()
      )
      ON CONFLICT (user_id, module_name) DO UPDATE SET
        can_view   = CASE WHEN _action = 'view'   THEN _value ELSE user_permissions.can_view   END,
        can_create = CASE WHEN _action = 'create' THEN _value ELSE user_permissions.can_create END,
        can_edit   = CASE WHEN _action = 'edit'   THEN _value ELSE user_permissions.can_edit   END,
        can_delete = CASE WHEN _action = 'delete' THEN _value ELSE user_permissions.can_delete END,
        source_role    = _user_role,
        overridden_by  = auth.uid(),
        overridden_at  = now(),
        updated_at     = now();

      _merged_count := _merged_count + 1;
    END LOOP;

    -- Mark staging row as merged
    UPDATE public.perm_migration_staging
    SET migration_status = 'MERGED', merged_at = now()
    WHERE id = _row.id;
  END LOOP;

  RAISE NOTICE '✅ Merged % permission entries, skipped %', _merged_count, _skipped_count;
END $$;

COMMIT;
```

