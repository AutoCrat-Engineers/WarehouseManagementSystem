# Supabase Edge Functions — Environment Variables Template
#
# Copy this file to `.env` in the same directory for local development.
# Do NOT commit `.env` — it is gitignored.
# Production values are set via `supabase secrets set KEY=VALUE --project-ref <ref>`.

# ── Auto-injected by Supabase in deployed functions ─────────────────────────
# These are automatically available in production. Only set them locally
# to run functions via the local dev server.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_SECRET
SUPABASE_DB_URL=postgres://postgres:password@host:5432/postgres

# ── Custom secrets (must be set via `supabase secrets set`) ─────────────────
# Supabase blocks any env name prefixed with SUPABASE_*, so we use a custom
# name for the publishable key passed to `auth.getUser()`.

PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE
